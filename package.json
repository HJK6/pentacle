{
  "name": "pentacle",
  "version": "1.0.0",
  "description": "tmux session dashboard with embedded terminals",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "node scripts/postinstall.js",
    "build": "electron-builder",
    "build:mac": "node scripts/build-mac.js",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "deploy": "./deploy-mac.sh"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1028.0",
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/client-sqs": "^3.1030.0",
    "@aws-sdk/lib-dynamodb": "^3.1028.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "ssh2": "^1.17.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.bartimaeus.pentacle",
    "productName": "Pentacle",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dir",
      "hardenedRuntime": false
    },
    "linux": {
      "target": "dir",
      "category": "Development"
    },
    "win": {
      "target": "dir"
    },
    "files": [
      "**/*",
      "!scripts"
    ],
    "asarUnpack": [
      "mic-server/**",
      "server/**"
    ]
  }
}
