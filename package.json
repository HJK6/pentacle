{
  "name": "pentacle",
  "version": "1.0.0",
  "description": "tmux session dashboard with embedded terminals",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-rebuild",
    "build": "electron-builder --mac && rm -rf /Applications/Pentacle.app && cp -R dist/mac-arm64/Pentacle.app /Applications/Pentacle.app",
    "deploy": "./deploy.sh"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1028.0",
    "@aws-sdk/lib-dynamodb": "^3.1028.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.bartimaeus.pentacle",
    "productName": "Pentacle",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dir",
      "hardenedRuntime": false
    },
    "files": [
      "**/*",
      "!scripts"
    ]
  }
}
