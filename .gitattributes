# Normalize all text files to LF in the repo and on checkout.
# Pentacle is shared across macOS and Windows/WSL; LF everywhere avoids
# spurious whole-file diffs when tools auto-convert line endings.
* text=auto eol=lf

# Explicit binary markers (don't touch these)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
